{
  "name": "muggl3mind.github.io",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "description": "Lovely McInerney — portfolio.",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "audit:corpus": "node --experimental-strip-types scripts/audit-corpus.ts",
    "build:corpus": "node --experimental-strip-types scripts/audit-corpus.ts && node --experimental-strip-types scripts/build-corpus.ts",
    "worker:deploy": "wrangler deploy --cwd worker",
    "worker:tail": "wrangler tail --cwd worker",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@astrojs/rss": "^4.0.7",
    "@astrojs/sitemap": "^3.2.1",
    "@astrojs/tailwind": "5.1.2",
    "astro": "^4.16.0",
    "fast-xml-parser": "^4.5.0",
    "tailwindcss": "^3.4.14"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.5.41",
    "@cloudflare/workers-types": "^4.20260409.1",
    "vitest": "^2.1.9",
    "wrangler": "^4.81.1"
  }
}
